<!-- SERVICIOS -->
<section class="section" id="servicios">
  <div class="container">
    <div class="section-header">
      <span class="section-tag">Nuestra flota especializada</span>
      <h2 class="section-title">Servicios de <span class="accent">transporte</span></h2>
      <p class="section-desc">Cinco modalidades de carga para cubrir todas las necesidades logísticas de Panamá.</p>
    </div>
    <div class="services-grid">
      <div class="service-card" data-service="seca">
        <div class="svc-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="M16 8h4l3 3v5h-7V8z"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
        </div>
        <h3>Carga Seca</h3>
        <p>Contenedores de 24, 48 y 53 pies para carga general consolidada o completa.</p>
        <div class="svc-tags"><span>24 pies</span><span>48 pies</span><span>53 pies</span></div>
      </div>
      <div class="service-card featured" data-service="refrigerada">
        <div class="svc-badge">⭐ Premium</div>
        <div class="svc-icon cold">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2v20M4.93 4.93l14.14 14.14M2 12h20M4.93 19.07l14.14-14.14"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <h3>Carga Refrigerada</h3>
        <p>Cadena de frío garantizada con monitoreo en tiempo real. Contenedores de 24 y 56 pies.</p>
        <div class="svc-tags"><span>24 pies</span><span>56 pies</span><span>-18°C a +10°C</span></div>
      </div>
      <div class="service-card" data-service="cisterna">
        <div class="svc-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><ellipse cx="12" cy="12" rx="10" ry="6"/><path d="M2 12v4c0 3.31 4.48 6 10 6s10-2.69 10-6v-4"/></svg>
        </div>
        <h3>Cisternas</h3>
        <p>Transporte de líquidos a granel con cisternas de 4,000 galones de capacidad.</p>
        <div class="svc-tags"><span>4,000 gal</span><span>Líquidos</span></div>
      </div>
      <div class="service-card" data-service="mesa">
        <div class="svc-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="10" rx="2"/><path d="M6 17v3M18 17v3M2 11h20"/></svg>
        </div>
        <h3>Carga en Mesas</h3>
        <p>Flatbeds de 48 pies para estructuras pesadas, maquinaria y cargas sobredimensionadas.</p>
        <div class="svc-tags"><span>Flatbed 48 pies</span><span>Pesado</span></div>
      </div>
      <div class="service-card" data-service="botellera">
        <div class="svc-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M8 2h8l2 4H6L8 2zM6 6h12v14a2 2 0 01-2 2H8a2 2 0 01-2-2V6z"/><path d="M10 11v6M14 11v6"/></svg>
        </div>
        <h3>Mesa Botellera</h3>
        <p>Plataformas especializadas de 53 pies para contenedores de bebidas y líquidos envasados.</p>
        <div class="svc-tags"><span>53 pies</span><span>Contenedores</span></div>
      </div>
    </div>
  </div>
</section>
 
<!-- COTIZADOR IA -->
<section class="section dark-section" id="cotizador">
  <div class="container">
    <div class="section-header">
      <span class="section-tag ai-tag">✦ Inteligencia Artificial</span>
      <h2 class="section-title">Cotizador <span class="accent">con IA</span></h2>
      <p class="section-desc">Ingresa los datos de tu carga y nuestra IA calcula el precio estimado al instante, considerando ruta, temporada y tipo de servicio.</p>
    </div>
    <div class="cotizador-layout">
      <div class="cotizador-form-wrap">
        <div class="form-card">
          <div class="form-section-title">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
            Datos de la carga
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Tipo de servicio</label>
              <select id="cot-tipo">
                <option value="">Seleccionar...</option>
                <option value="seca">Carga seca</option>
                <option value="refrigerada">Carga refrigerada</option>
                <option value="cisterna">Cisterna</option>
                <option value="mesa">Mesa / Flatbed</option>
                <option value="botellera">Mesa botellera</option>
              </select>
            </div>
            <div class="form-group">
              <label>Urgencia</label>
              <select id="cot-urgencia">
                <option value="normal">Normal (3–5 días)</option>
                <option value="urgente">Urgente (24–48 h)</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Origen</label>
              <select id="cot-origen">
                <option value="">Seleccionar provincia</option>
                <option>Ciudad de Panamá</option>
                <option>Colón</option>
                <option>Coclé</option>
                <option>Chiriquí</option>
                <option>Veraguas</option>
                <option>Herrera</option>
                <option>Los Santos</option>
                <option>Bocas del Toro</option>
                <option>Darién</option>
              </select>
            </div>
            <div class="form-group">
              <label>Destino</label>
              <select id="cot-destino">
                <option value="">Seleccionar provincia</option>
                <option>Ciudad de Panamá</option>
                <option>Colón</option>
                <option>Coclé</option>
                <option>Chiriquí</option>
                <option>Veraguas</option>
                <option>Herrera</option>
                <option>Los Santos</option>
                <option>Bocas del Toro</option>
                <option>Darién</option>
              </select>
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label>Peso estimado (kg)</label>
              <input type="number" id="cot-peso" placeholder="Ej: 5000" min="0">
            </div>
            <div class="form-group">
              <label>Contacto</label>
              <input type="text" id="cot-contacto" placeholder="Nombre y teléfono">
            </div>
          </div>
          <button class="btn-primary full" id="btnCotizar" onclick="cotizarIA()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Calcular con IA
          </button>
        </div>
      </div>
      <div class="cotizador-result" id="cotizadorResult">
        <div class="result-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          <p>Completa el formulario y la IA analizará tu solicitud al instante</p>
        </div>
      </div>
    </div>
  </div>
</section>
 
<!-- MONITOREO CADENA FRÍA -->
<section class="section" id="monitoreo">
  <div class="container">
    <div class="section-header">
      <span class="section-tag ai-tag">✦ Monitoreo en Tiempo Real</span>
      <h2 class="section-title">Control de <span class="accent">cadena de frío</span></h2>
      <p class="section-desc">Sistema de IA que detecta anomalías de temperatura y predice fallas antes de que ocurran.</p>
    </div>
    <div class="monitor-layout">
      <div class="monitor-panel">
        <div class="monitor-header">
          <div class="monitor-title">
            <span class="status-dot active"></span>
            Dashboard de flota refrigerada
          </div>
          <button class="btn-sm" onclick="simularAlerta()">Simular alerta</button>
        </div>
        <div class="trucks-list" id="trucksList">
          <!-- generado por JS -->
        </div>
      </div>
      <div class="monitor-side">
        <div class="alert-panel" id="alertPanel">
          <div class="alert-header">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Alertas IA
          </div>
          <div class="alert-list" id="alertList">
            <div class="alert-empty">Sin alertas activas. Sistema operando normalmente.</div>
          </div>
        </div>
        <div class="ia-insight" id="iaInsight">
          <div class="insight-label">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
            Análisis IA
          </div>
          <p id="insightText">Todos los vehículos refrigerados operando dentro de parámetros normales. Temperatura promedio de flota: <strong>-4.2°C</strong>. No se detectan anomalías.</p>
        </div>
      </div>
    </div>
  </div>
</section>
 
<!-- ASISTENTE IA -->
<section class="section dark-section" id="asistente">
  <div class="container">
    <div class="section-header">
      <span class="section-tag ai-tag">✦ Asistente Virtual</span>
      <h2 class="section-title">Asistente <span class="accent">TARA</span></h2>
      <p class="section-desc">Transporte Carranza AI — responde preguntas, cotiza y asesora sobre logística en tiempo real.</p>
    </div>
    <div class="chat-container">
      <div class="chat-header">
        <div class="chat-avatar">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </div>
        <div>
          <div class="chat-name">TARA — Asistente TRACASA</div>
          <div class="chat-status"><span class="status-dot active small"></span> En línea</div>
        </div>
      </div>
      <div class="chat-messages" id="chatMessages">
        <div class="msg bot">
          <div class="msg-bubble">¡Hola! Soy <strong>TARA</strong>, el asistente virtual de Transporte Carranza. Puedo ayudarte con cotizaciones, información de servicios, tiempos de entrega y asesoría logística. ¿En qué te puedo ayudar?</div>
          <div class="msg-time">Ahora</div>
        </div>
        <div class="chat-suggestions">
          <button onclick="enviarSugerencia('¿Cuáles son sus servicios de carga refrigerada?')">🧊 Carga refrigerada</button>
          <button onclick="enviarSugerencia('¿Cuánto cuesta llevar carga de Panamá a Chiriquí?')">💰 Precios</button>
          <button onclick="enviarSugerencia('¿Cuáles son los tiempos de entrega?')">⏱ Tiempos</button>
          <button onclick="enviarSugerencia('¿Qué documentos necesito para contratar el servicio?')">📋 Requisitos</button>
        </div>
      </div>
      <div class="chat-input-area">
        <input type="text" id="chatInput" placeholder="Escribe tu pregunta..." onkeydown="if(event.key==='Enter')enviarMensaje()">
        <button class="btn-send" onclick="enviarMensaje()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
        </button>
      </div>
    </div>
  </div>
</section>
 
<!-- REPORTES IA -->
<section class="section" id="reportes">
  <div class="container">
    <div class="section-header">
      <span class="section-tag ai-tag">✦ IA para Operaciones</span>
      <h2 class="section-title">Reporte de <span class="accent">manejo</span></h2>
      <p class="section-desc">El sistema clasifica automáticamente el tipo de incidencia y genera alertas inteligentes al equipo correspondiente.</p>
    </div>
    <div class="reporte-layout">
      <div class="form-card light">
        <div class="form-section-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Nuevo reporte
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Fecha del reporte</label>
            <input type="date" id="rep-fecha">
          </div>
          <div class="form-group">
            <label>Nombre del chofer</label>
            <input type="text" id="rep-chofer" placeholder="Nombre completo">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>Placa del vehículo</label>
            <input type="text" id="rep-placa" placeholder="Ej: PA-1234">
          </div>
          <div class="form-group">
            <label>Contacto</label>
            <input type="text" id="rep-contacto" placeholder="Teléfono">
          </div>
        </div>
        <div class="form-group full">
          <label>Descripción del reporte</label>
          <textarea id="rep-descripcion" rows="4" placeholder="Describe el incidente, manejo de carga u observación relevante..."></textarea>
        </div>
        <button class="btn-primary full" onclick="analizarReporte()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          Enviar y analizar con IA
        </button>
      </div>
      <div class="reporte-result" id="reporteResult">
        <div class="result-placeholder">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          <p>La IA clasificará automáticamente el tipo de incidencia y sugerirá las acciones a tomar</p>
        </div>
      </div>
    </div>
  </div>
</section>
 
<!-- CONTACTO -->
<section class="section dark-section" id="contacto">
  <div class="container">
    <div class="contact-grid">
      <div class="contact-info">
        <span class="section-tag">¿Necesitas más info?</span>
        <h2 class="section-title">Contáctanos<span class="accent">.</span></h2>
        <p class="section-desc">Estamos en Natá, Coclé, cubriendo todo Panamá con responsabilidad y puntualidad.</p>
